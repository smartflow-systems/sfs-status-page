# SFS Status Page - Development Environment
# This is a template - update DATABASE_URL with your actual database

# Database (Required)
# Get a free database at: https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@localhost:5432/sfs_status

# Server
PORT=5000
NODE_ENV=development

# Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=dev-jwt-secret-change-in-production
SESSION_SECRET=dev-session-secret-change-in-production

# Optional: Email notifications (sign up at https://resend.com)
# RESEND_API_KEY=re_your_key
# EMAIL_FROM=status@yourdomain.com

# Optional: SMS alerts
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_PHONE_NUMBER=+1234567890

# Features
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AUTO_INCIDENTS=true
ENABLE_WEBHOOKS=true
