# ============================================================================
# SFS STATUS PAGE - ENVIRONMENT CONFIGURATION
# ============================================================================

# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------

# PostgreSQL database URL (Neon, Supabase, or any PostgreSQL provider)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/sfs_status

# ----------------------------------------------------------------------------
# SERVER
# ----------------------------------------------------------------------------

# Server port (default: 5000)
PORT=5000

# Node environment (development | production | test)
NODE_ENV=development

# ----------------------------------------------------------------------------
# AUTHENTICATION
# ----------------------------------------------------------------------------

# JWT secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# ----------------------------------------------------------------------------
# EMAIL SERVICE (Optional - for notifications)
# ----------------------------------------------------------------------------

# Resend API Key (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key

# SendGrid API Key (alternative to Resend)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Email from address
EMAIL_FROM=status@yourdomain.com

# ----------------------------------------------------------------------------
# SMS SERVICE (Optional - for critical alerts)
# ----------------------------------------------------------------------------

# Twilio credentials (https://twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ----------------------------------------------------------------------------
# INTEGRATIONS (Optional)
# ----------------------------------------------------------------------------

# Slack Bot Token (for Slack notifications)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# PagerDuty Integration Key
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key

# Opsgenie API Key
OPSGENIE_API_KEY=your_opsgenie_api_key

# ----------------------------------------------------------------------------
# MONITORING (Optional)
# ----------------------------------------------------------------------------

# Number of concurrent health checks
MAX_CONCURRENT_CHECKS=10

# Default check interval in seconds
DEFAULT_CHECK_INTERVAL=60

# Check timeout in seconds
DEFAULT_CHECK_TIMEOUT=30

# ----------------------------------------------------------------------------
# RATE LIMITING (Optional)
# ----------------------------------------------------------------------------

# Rate limit requests per minute
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# CORS (Optional)
# ----------------------------------------------------------------------------

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ----------------------------------------------------------------------------
# ANALYTICS (Optional)
# ----------------------------------------------------------------------------

# PostHog API Key (for product analytics)
POSTHOG_API_KEY=phc_your_posthog_key

# Sentry DSN (for error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ----------------------------------------------------------------------------
# STORAGE (Optional - for logo/favicon uploads)
# ----------------------------------------------------------------------------

# AWS S3 credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=sfs-status-uploads
AWS_REGION=us-east-1

# Cloudflare R2 (alternative to S3)
# R2_ACCOUNT_ID=your_r2_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=sfs-status-uploads

# ----------------------------------------------------------------------------
# FEATURES FLAGS (Optional)
# ----------------------------------------------------------------------------

# Enable/disable specific features
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_ALERTS=false
ENABLE_WEBHOOKS=true
ENABLE_AUTO_INCIDENTS=true
ENABLE_MAINTENANCE_MODE=true

# ----------------------------------------------------------------------------
# PRODUCTION SETTINGS
# ----------------------------------------------------------------------------

# Base URL for status pages
BASE_URL=https://status.sfs.com

# Custom domain support
ENABLE_CUSTOM_DOMAINS=false

# White-label mode (remove "Powered by SFS" branding)
WHITE_LABEL_ENABLED=false
